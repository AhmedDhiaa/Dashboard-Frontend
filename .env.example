# ─────────────────────────────────────────────────────────────────────────────
# STANDALONE MOCK MODE  (frontend-only template — NO backend required)
# ─────────────────────────────────────────────────────────────────────────────
# When "true", the whole app runs on seeded in-memory mock data:
#   - login works offline (demo / demo),
#   - the demo user has ALL permissions (every nav item + action visible),
#   - all tables, KPI cards, charts and maps are populated,
#   - create/update/delete persist for the browser session.
# When "false" or unset, the app behaves exactly as before (real backend).
# See docs/FRONTEND-TEMPLATE.md and src/infra/api/mock/.
NEXT_PUBLIC_USE_MOCK_API=true

# ─────────────────────────────────────────────────────────────────────────────
# BRAND / WHITE-LABEL  (rebrand the whole app with two variables)
# ─────────────────────────────────────────────────────────────────────────────
# Display name shown in the UI/titles/emails, and the primary brand domain used
# for demo emails, image allow-lists and doc examples. Defaults are neutral
# placeholders ("Acme" / "example.com"). See src/shared/config/brand.ts.
NEXT_PUBLIC_APP_NAME=Acme
NEXT_PUBLIC_BRAND_DOMAIN=example.com

# API
# In mock mode this is just a harmless placeholder (no requests reach it).
# To connect a real backend: set NEXT_PUBLIC_USE_MOCK_API=false and point this
# at your ABP API root.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Auth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-minimum-32-chars
AUTH_SECRET=your-secret-here-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# OAuth2 Provider
NEXT_PUBLIC_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_ISSUER=

# Maps
# Map provider: "google" (needs the API key below) or "leaflet" (free
# OpenStreetMap, no key required). Defaults to "google".
NEXT_PUBLIC_MAP_PROVIDER=google
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Socket
NEXT_PUBLIC_SOCKET_URL=

# Logging
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_LOG_ENDPOINT=

# Error reporting — webhook for structured JSON error payloads
# ({kind, name, message, stack, correlationId, tags, extra, ts}). When unset
# AND no Sentry DSN is configured, errors stay on the console.
NEXT_PUBLIC_ERROR_REPORT_ENDPOINT=

# Sentry — observability + error reporting
# - When a DSN is set, every error reported through `errorReporter` is sent
#   to Sentry (and still logged locally).
# - The PUBLIC_ DSN reaches the client bundle; the non-PUBLIC one is used
#   server-side / in instrumentation. Both can be the same value.
# - Performance traces are sampled at 10 % by default; raise for short
#   investigations, do NOT raise to 1.0 in production.
# - SENTRY_AUTH_TOKEN is only needed in CI for source-map upload — the
#   build runs fine without it.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Feature flags
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_MAPS=true

# Runtime builder backend
# - "server" (default): entities + records are stored on the server under
#   messages/_overrides/runtime/, so every admin sees the same data.
# - "local": stores everything in localStorage. Each browser is its own
#   private database. Useful for offline demos / development only.
NEXT_PUBLIC_RUNTIME_BACKEND=server

# Runtime codegen — DEV ONLY
#
# When set to "true", the entity-builder, widget-builder, and
# runtime-builder "materialize" pipelines are allowed to write actual
# source files into the repo (src/domains/<...>, src/app/(dashboard)/<...>,
# src/features/dashboard/widgets/<...>, plus messages/{en,ar}/pages.json).
#
# Treat this as a remote file-write primitive: any admin who can reach the
# materialize endpoints can overwrite any file the safe-path allowlist
# permits. Keep it OFF in production.
#
# The platform refuses to start if this flag is "true" in production
# UNLESS the explicit override below is set. The startup safeguard lives
# in instrumentation.ts.
APP_ALLOW_RUNTIME_CODEGEN=

# DO NOT SET. This is a documented override that bypasses the production
# safeguard above; it exists only so an internal staging instance with no
# real users can deliberately turn codegen on. The literal value is
# `i-understand-the-risks` — anything else (including "true" / "1" / "yes")
# leaves the safeguard active. CI's `check:codegen-flag` script blocks any
# .env* file checked into the repo from setting BOTH this var AND
# APP_ALLOW_RUNTIME_CODEGEN=true.
APP_ALLOW_RUNTIME_CODEGEN_PROD_OVERRIDE=

# Rate-limit backend (production / multi-instance only)
#
# Without these set, the limiter uses an in-memory counter. That's fine
# for `next dev` and single-process deployments, but USELESS behind a
# load balancer — each instance counts only its own traffic, so an
# attacker who lands on different instances effectively gets `N × max`
# per window. Pick ONE of the two paths below for any horizontally-scaled
# production deployment.
#
# Path A: Upstash REST (preferred for edge runtime)
#   Pure HTTP, edge-runtime-compatible, zero-ops Redis. The right pick
#   when middleware runs on Vercel's edge or any other edge runtime.
#   Install: `npm install @upstash/redis`
# UPSTASH_REDIS_REST_URL=https://<your-instance>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<token-from-upstash-console>
#
# Path B: ioredis (self-hosted Redis, Node.js runtime only)
#   TCP-based; CANNOT run on the edge. Use when self-hosting Redis
#   inside a private network and the middleware is configured for the
#   Node.js runtime (`export const runtime = "nodejs"`).
#   Install: `npm install ioredis`
# REDIS_URL=redis://default:<password>@<host>:<port>
