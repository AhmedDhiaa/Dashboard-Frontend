<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS / Azure App Service (Windows) config for the Next.js standalone bundle.
  Place this next to server.js (the publish packager copies it to the bundle
  root automatically). Requires the iisnode module + Node 22 on the host.

  Set app settings (NEXTAUTH_SECRET, NEXTAUTH_URL, NEXT_PUBLIC_API_URL, …) in
  the IIS Application Settings / Azure Configuration, NOT in this file.
-->
<configuration>
  <system.webServer>
    <!-- Route Node through iisnode. -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Serve real files/dirs (static assets) straight from disk. -->
        <rule name="StaticContent" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAny">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>
        <!-- Everything else → the Node server. -->
        <rule name="DynamicContent">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Let Node own error responses. -->
    <httpErrors existingResponse="PassThrough" />

    <iisnode nodeProcessCommandLine="node.exe" node_env="production" />
  </system.webServer>
</configuration>
