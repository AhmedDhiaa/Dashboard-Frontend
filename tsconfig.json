{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": [
      "google.maps",
      "vitest/globals"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/app/*": [
        "./src/app/*"
      ],
      "@/features/*": [
        "./src/features/*"
      ],
      "@/domains/*": [
        "./src/domains/*"
      ],
      "@/core/*": [
        "./src/core/*"
      ],
      "@/infra/*": [
        "./src/infra/*"
      ],
      "@/ui/*": [
        "./src/ui/*"
      ],
      "@/ui/design-system/*": [
        "./src/ui/design-system/*"
      ],
      "@/ui/application/*": [
        "./src/ui/application/*"
      ],
      "@/shared/*": [
        "./src/shared/*"
      ],
      "@/types/*": [
        "./src/shared/types/*"
      ],
      "@/types/field-types": [
        "./src/shared/types/field-types"
      ]
    },
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    // exactOptionalPropertyTypes: true would surface ~200 errors across pages
    // (mostly Next.js dynamic-route `id?: string` vs `id?: string | undefined`
    // mismatches in config-driven edit pages, plus a handful of CRUDListPage
    // call sites). Tracked as a follow-up — the fix is mechanical but touches
    // 50+ files and warrants its own focused PR.
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "files_extracted",
    "e2e",
    "playwright.config.ts",
    "src/shared/test-utils/msw/handlers.ts"
  ]
}
