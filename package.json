{
  "name": "acme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "init-entities": "tsx scripts/generate-entity-init.ts",
    "validate": "npm run init-entities && tsx scripts/validate-architecture.ts",
    "build": "npm run init-entities && npm run quality && next build --webpack && npm run check:leaked-secrets",
    "build:server": "tsx --tsconfig tsconfig.json server.ts --emit",
    "build:full": "npm run build && npm run build:server",
    "publish:bundle": "node scripts/publish.mjs",
    "publish:pack": "node scripts/publish.mjs --skip-build",
    "dev": "npm run init-entities && tsx server.ts",
    "dev:next": "next dev --turbopack",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "start": "cross-env NODE_ENV=production node .next/standalone/server.js",
    "start:next": "next start",
    "type-check": "tsc --noEmit",
    "check:next-auth-pin": "node scripts/check-next-auth-pin.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:dead-code": "node scripts/check-knip.mjs",
    "check:prerelease-deps": "node scripts/check-prerelease-deps.mjs",
    "check:leaked-secrets": "node scripts/check-leaked-secrets.mjs",
    "check:codegen-flag": "node scripts/check-codegen-flag.mjs",
    "check:i18n-parity": "node scripts/check-i18n-parity.mjs",
    "check:i18n-usage": "node scripts/check-i18n-usage.mjs",
    "check:rsc-boundaries": "node scripts/check-rsc-boundaries.mjs",
    "check:swagger-drift": "node scripts/check-swagger-drift.mjs",
    "check:color-fn": "node scripts/check-color-fn.mjs",
    "test:ratelimit": "tsx scripts/load-test-ratelimit.ts",
    "analyze": "cross-env ANALYZE=true npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e:rtl": "playwright test --project=chromium-rtl",
    "test:e2e:rtl:update": "playwright test --project=chromium-rtl --update-snapshots",
    "docs:build": "echo 'Documentation is in README.md, ARCHITECTURE.md, and CONTRIBUTING.md'",
    "docs:serve": "echo 'Open README.md in your editor or browser'",
    "clean": "rm -rf .next node_modules/.cache",
    "clean:all": "rm -rf .next node_modules",
    "quality": "npm run type-check && npm run lint && npm run validate && npm run check:next-auth-pin && npm run check:leaked-secrets && npm run check:codegen-flag && npm run check:i18n-parity && npm run check:i18n-usage && npm run check:rsc-boundaries && npm run check:swagger-drift && npm run check:color-fn",
    "prepare": "husky",
    "release": "standard-version",
    "release:major": "standard-version --release-as major",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "postrelease": "git push --follow-tags",
    "plop": "plop"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/signalr": "^10.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-dropzone": "^15.0.0",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "3.64.0",
    "@types/node": "~22.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.6.0",
    "openapi-types": "^12.1.3",
    "plop": "^4.0.5",
    "postcss": "^8.5",
    "prettier": "^3.8.3",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  },
  "description": "Modern, scalable Next.js application for business analytics and management.",
  "main": "tailwind.config.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module"
}
